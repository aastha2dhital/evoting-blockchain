    <string name="admin_pin_supporting">यस प्रोटोटाइपका लागि सुरक्षित प्रशासक नियन्त्रण पोर्टल अनलक गर्न आवश्यक छ।</string>
    <string name="admin_continue_dashboard">प्रशासक ड्यासबोर्डमा जानुहोस्</string>
